# Server-side only. Never prefix this with VITE_ and never import it in src/.
DEEPSEEK_API_KEY=replace_with_your_deepseek_api_key

# Low-latency official model. Keep configurable for future model migrations.
DEEPSEEK_MODEL=deepseek-v4-flash

# Optional cross-instance sentence cache. Both values stay server-side.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=sb_secret_replace_with_your_server_secret
